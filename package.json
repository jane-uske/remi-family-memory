{
  "name": "remi-family-memory",
  "version": "1.1.1",
  "description": "A local-first family memory system — Grounded Answer Protocol for Remi/AI",
  "type": "module",
  "main": "./dist/remi-adapter.js",
  "types": "./dist/remi-adapter.d.ts",
  "exports": {
    ".": {
      "import": "./dist/remi-adapter.js",
      "types": "./dist/remi-adapter.d.ts"
    },
    "./connector": {
      "import": "./dist/connector.js",
      "types": "./dist/connector.d.ts"
    }
  },
  "scripts": {
    "scan": "tsx src/cli.ts scan",
    "sync": "tsx src/cli.ts sync",
    "scan-assets": "tsx src/cli.ts scan-assets",
    "intake-assets": "tsx src/cli.ts intake-assets",
    "extract-ocr": "tsx src/cli.ts extract-ocr",
    "enrich-draft": "tsx src/cli.ts enrich-draft",
    "enrich-drafts": "tsx src/cli.ts enrich-drafts",
    "serve": "tsx src/cli.ts serve",
    "dev": "tsx src/cli.ts dev",
    "report": "tsx src/cli.ts report",
    "build-memory": "tsx src/cli.ts build-memory",
    "context": "tsx src/cli.ts context",
    "search": "tsx src/cli.ts search",
    "export": "tsx src/cli.ts export",
    "doctor": "tsx src/cli.ts doctor",
    "connector": "tsx src/cli.ts connector",
    "connector:degradation": "tsx src/cli.ts connector degradation",
    "capture-demo": "tsx src/cli.ts capture-demo",
    "test": "node --import tsx/esm --test src/tests/privacy.test.ts src/tests/adapter.test.ts src/tests/capture.test.ts src/tests/drafts.test.ts src/tests/ocr.test.ts src/tests/intake_ocr_grouping.test.ts src/tests/review_evidence.test.ts src/tests/draft-capability.test.ts src/tests/local_vlm_extractor.test.ts src/tests/draft_enrichment.test.ts src/tests/confirmed-only-guard.test.ts src/tests/provenance.test.ts src/tests/daily-flow.test.ts",
    "vlm:smoke": "tsx src/cli.ts vlm-smoke",
    "llm:smoke": "tsx src/llm-smoke.ts",
    "llm:e2e": "tsx src/llm-e2e.ts",
    "remi:smoke": "tsx src/remi-smoke.ts",
    "build": "tsc"
  },
  "dependencies": {
    "express": "^4.21.0",
    "gray-matter": "^4.0.3",
    "nanoid": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
