{
  "name": "remi-family-memory",
  "version": "0.8.2",
  "description": "A local-first family memory system — Grounded Answer Protocol for Remi/AI",
  "type": "module",
  "main": "./dist/remi-adapter.js",
  "types": "./dist/remi-adapter.d.ts",
  "exports": {
    ".": {
      "import": "./dist/remi-adapter.js",
      "types": "./dist/remi-adapter.d.ts"
    },
    "./connector": {
      "import": "./dist/connector.js",
      "types": "./dist/connector.d.ts"
    }
  },
  "scripts": {
    "scan": "tsx src/cli.ts scan",
    "scan-assets": "tsx src/cli.ts scan-assets",
    "serve": "tsx src/cli.ts serve",
    "dev": "tsx src/cli.ts dev",
    "report": "tsx src/cli.ts report",
    "build-memory": "tsx src/cli.ts build-memory",
    "context": "tsx src/cli.ts context",
    "search": "tsx src/cli.ts search",
    "export": "tsx src/cli.ts export",
    "doctor": "tsx src/cli.ts doctor",
    "connector": "tsx src/cli.ts connector",
    "connector:degradation": "tsx src/cli.ts connector degradation",
    "test": "node --import tsx/esm --test src/tests/privacy.test.ts src/tests/adapter.test.ts",
    "llm:smoke": "tsx src/llm-smoke.ts",
    "llm:e2e": "tsx src/llm-e2e.ts",
    "remi:smoke": "tsx src/remi-smoke.ts",
    "build": "tsc"
  },
  "dependencies": {
    "express": "^4.21.0",
    "gray-matter": "^4.0.3",
    "nanoid": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
